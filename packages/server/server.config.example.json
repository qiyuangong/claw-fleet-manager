{
  "_comment": "Docker instances work when Docker is available. Add a 'profiles' block to also manage profile instances.",
  "port": 3001,
  "auth": { "username": "admin", "password": "changeme" },
  "fleetDir": "/path/to/your/openclaw-fleet",

  "_comment_profiles": "Optional — add this block to enable profile (native openclaw --profile) instances",
  "_profiles": {
    "openclawBinary": "openclaw",
    "basePort": 18789,
    "portStep": 20,
    "stateBaseDir": "~/.openclaw-states",
    "configBaseDir": "~/.openclaw-configs",
    "autoRestart": true,
    "stopTimeoutMs": 10000
  },

  "tailscale": { "hostname": "your-machine.tailnet.ts.net" },
  "tls": { "cert": "/path/to/cert.pem", "key": "/path/to/key.pem" }
}
